{
  "name": "malleable-plc-poc",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:db": "docker compose up -d postgres && echo 'Postgres ready on :${PG_PORT:-5433}'",
    "dev:migrate": "DATABASE_URL=postgres://pls:pls@localhost:${PG_PORT:-5433}/malleable_pls pnpm --filter @pls/server run migrate",
    "dev:server": "DATABASE_URL=postgres://pls:pls@localhost:${PG_PORT:-5433}/malleable_pls pnpm --filter @pls/server run dev",
    "dev:web": "VITE_API_URL=http://localhost:3001 VITE_USER_ID=dev-user-1 pnpm --filter @pls/web run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ct": "playwright test --config playwright-ct.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.60.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@tanstack/react-query": "^5.99.0",
    "@trpc/client": "^11.1.0",
    "@trpc/react-query": "^11.1.0",
    "superjson": "^2.2.6",
    "zustand": "^5.0.0",
    "typescript": "~5.8.3",
    "vitest": "^4.1.5"
  }
}
